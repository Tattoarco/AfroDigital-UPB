# =========================================
# AfroDigital UPB — .gitignore
# Cubre: afrodigital-api (Node/Express) +
#        afrodigital-web (React/Vite)
# =========================================

# ---------- Dependencias ----------
node_modules/
**/node_modules/
.pnp
.pnp.js
jspm_packages/

# ---------- Variables de entorno ----------
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ---------- Builds y salidas de compilación ----------
dist/
dist-ssr/
build/
out/
.vite/
.next/
*.tsbuildinfo

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Cache ----------
.cache/
.parcel-cache/
.eslintcache
.turbo/

# ---------- Testing / cobertura ----------
coverage/
*.lcov
.nyc_output/

# ---------- Supabase (CLI local) ----------
.supabase/
supabase/.branches/
supabase/.temp/

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ---------- Sistema operativo ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---------- Archivos temporales ----------
tmp/
temp/
*.tmp

# ---------- Paquetes / archivos comprimidos ----------
*.zip
*.tar.gz
*.rar

# ---------- Certificados / llaves locales ----------
*.pem
*.key
!docs/**/*.pem

# ---------- Vercel / Render (metadatos de despliegue local) ----------
.vercel/
.render/

# ---------- Gestores de paquetes (bloquea solo si usas otro) ----------
# Descomenta el que NO uses en el proyecto para evitar conflictos:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml